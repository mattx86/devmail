# Ubuntu 24.04 container for running and testing devmail.
# Starts devmail, then sends 10 Lorem Ipsum test emails via swaks (~16 MB, 50% of default limit).
#
# Build (Linux binary must be in dist/ first):
#   docker build -f Dockerfile.test -t devmail-test .
#   docker run --rm -p 1025:1025 -p 8085:8085 devmail-test
#
# Then open http://127.0.0.1:8085 in your browser.
#
# To test with disk storage:
#   docker run --rm -p 1025:1025 -p 8085:8085 devmail-test --store

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    ca-certificates \
    swaks \
    && rm -rf /var/lib/apt/lists/*

COPY dist/devmail               /usr/local/bin/devmail
COPY test/entrypoint.sh         /usr/local/bin/entrypoint.sh
COPY test/gen-test-emails.sh    /usr/local/bin/gen-test-emails.sh
RUN chmod +x \
    /usr/local/bin/devmail \
    /usr/local/bin/entrypoint.sh \
    /usr/local/bin/gen-test-emails.sh

EXPOSE 1025 8085

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
# Override listen addresses so ports are reachable via -p from the host.
# (Default 127.0.0.1 is the container's own loopback and is not port-mapped.)
CMD ["--smtp-addr", "0.0.0.0:1025", "--http-addr", "0.0.0.0:8085"]
